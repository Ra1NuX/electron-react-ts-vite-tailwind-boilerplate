{
    "name": "example",
    "author": {
        "name": "Ra1NuX",
        "email": "ra1nux.01@gmail.com"
    },
    "version": "0.0.0",
    "type": "module",
    "main": "electron/electron.ts",
    "scripts": {
        "dev": "vite",
        "build:electron": "bun ./esbuild.config.mjs",
        "build:renderer": "vite build",
        "build:dev:electron": "bun ./esbuild.config.mjs --watch",
        "build": "npm run build:renderer && npm run build:electron",
        "lint": "eslint .",
        "test": "jest",
        "preview": "vite preview",
        "start": "electronmon ./app/index.cjs",
        "electron:vite:build": "concurrently \"cross-env BROWSER=none bun dev\" \"wait-on http://localhost:5173 && bun build:dev:electron\"",
        "electron:dev": "concurrently \"bun electron:vite:build\" \"bun start\"",
        "dist": "npm run build && electron-builder --config electron-builder.config.js -w"
    },
    "dependencies": {
        "electron-updater": "^6.8.3",
        "electronmon": "^2.0.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.2.2",
        "@types/bun": "^1.2.4",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1",
        "eslint": "^10.1.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "tailwindcss": "^4.2.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3",
        "wait-on": "^8.0.2"
    },
    "build": {
        "appId": "com.example",
        "productName": "example",
        "copyright": "Copyright © 2021 ${author}",
        "linux": {
            "target": [
                "pacman"
            ],
            "icon": "build/icon.png"
        },
        "win": {
            "icon": "build/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "directories": {
            "buildResources": "assets",
            "output": "dist_electron"
        }
    }
}
