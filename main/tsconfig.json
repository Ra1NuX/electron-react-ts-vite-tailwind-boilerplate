{
    "compilerOptions": {
      "types": ["node"],
      "allowJs": true,
      "alwaysStrict": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "isolatedModules": true,
      "lib": ["es2022"],
      "module": "ESNext",
      "moduleResolution": "bundler",
      "noEmit": false,
      "noFallthroughCasesInSwitch": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "strict": true,
      "target": "es2022",
      "outDir": "../app",

      "paths": {
        "@core/*": ["./*"]
      }
    },
    "exclude": ["node_modules"],
    "include": ["**/*.ts", "**/*.tsx", "**/*.js", "index.cts", "index.ts"]
  }